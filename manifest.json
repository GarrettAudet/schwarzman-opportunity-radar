{
  "manifest_version": 3,
  "name": "Blackboard Resource Inventory",
  "version": "0.3.1",
  "description": "Crawl the currently logged-in Blackboard site and export a local resource inventory.",
  "permissions": ["sidePanel", "storage", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Blackboard Inventory"
  }
}
