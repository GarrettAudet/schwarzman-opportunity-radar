# Local secrets and environment
.env

# Local/private source config and durable state
data/config/sources.local.json
data/config/conditions.local.json
data/config/discovery.local.json
data/state/*.json

# Generated run outputs
data/runs/**
!data/runs/.gitkeep

# Raw fetched pages and debugging dumps
data/raw/**

# Python caches
__pycache__/
*.pyc

# Local deploy artifacts
.deploy-local/**
